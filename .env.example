# Copy this file to .env and fill in your real values.

# ---- MySQL connection ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=hospital_db

# Set to "true" when connecting to a managed MySQL host that requires SSL
# (Aiven, PlanetScale, most cloud providers). Leave unset for local XAMPP/MySQL.
DB_SSL=false
# Optional: path to a CA certificate file for stricter SSL validation. If left
# unset while DB_SSL=true, connects with certificate validation relaxed
# (works fine, just slightly less strict than pinning the provider's CA).
DB_SSL_CA_PATH=

# ---- App ----
PORT=5000
SESSION_SECRET=secret123

# ---- Patient chatbot (LLM + RAG) ----
# Free API key, no credit card needed (in most regions): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override which Gemini model the chatbot uses. Google renames/
# deprecates models fairly often - if the chat widget ever shows a "model not
# found" error, check https://ai.google.dev/gemini-api/docs/models for the
# current free-tier model name and set it here (no code changes needed).
GEMINI_MODEL=gemini-3-flash-preview
